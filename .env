# ── Development environment ───────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Variables prefixed with VITE_ are exposed to the browser bundle.
# Never put secrets (private keys, DB passwords) in VITE_ variables.

# Backend API base URL
# In development the Vite dev server proxies /api → localhost:8080,
# so you can leave this commented out unless your backend runs elsewhere.
VITE_API_BASE_URL=http://localhost:8080

# App metadata (optional — used in future analytics/tracking integrations)
VITE_APP_NAME=ShopZen
VITE_APP_ENV=development
